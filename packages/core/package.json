{
  "name": "@agentbrain/core",
  "version": "1.4.35",
  "description": "Shared intelligence layer for AgentBrain - smart context generation for coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "context",
    "documentation",
    "codebase",
    "claude",
    "cursor",
    "windsurf",
    "coding-agent"
  ],
  "author": "AgentBrain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/benmalcom/agentbrain.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/benmalcom/agentbrain/issues"
  },
  "homepage": "https://github.com/benmalcom/agentbrain#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "globby": "^14.0.2",
    "openai": "^4.77.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2"
  }
}
